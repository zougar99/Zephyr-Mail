{
  "manifest_version": 2,
  "name": "Zephyr Mail",
  "version": "1.0.0",
  "description": "Emails jetables, alias, confidentialité, anti-spam — temp mail, masking, tracking blocker.",
  "homepage_url": "https://t.me/werlist99",
  "permissions": [
    "activeTab",
    "storage",
    "clipboardWrite",
    "contextMenus",
    "notifications",
    "<all_urls>",
    "https://api.mail.gw/*",
    "https://www.1secmail.com/api/*"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "run_at": "document_end"
  }],
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Zephyr Mail — Emails jetables",
    "default_icon": {
      "16": "icons/icon16.svg",
      "48": "icons/icon48.svg",
      "128": "icons/icon128.svg"
    }
  },
  "icons": {
    "16": "icons/icon16.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "@werlist99-zephyr-mail",
      "data_collection_permissions": { "required": ["none"] }
    }
  },
  "developer": {
    "name": "werlist99",
    "url": "https://t.me/werlist99"
  }
}